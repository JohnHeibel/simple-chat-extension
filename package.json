{
  "name": "simple-chat-extension",
  "displayName": "Simple Chat",
  "description": "Simple OpenRouter chat with git diff support",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "browser": "./out/extension.js",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "simpleChat",
          "title": "Simple Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "simpleChat": [
        {
          "id": "simpleChatView",
          "name": "Conversations"
        },
        {
          "type": "webview",
          "id": "trialTaskView",
          "name": "Current Task"
        }
      ]
    },
    "commands": [
      {
        "command": "simpleChat.openChat",
        "title": "Open Chat",
        "category": "Simple Chat",
        "icon": "$(add)"
      },
      {
        "command": "simpleChat.configure",
        "title": "Configure OpenRouter",
        "category": "Simple Chat"
      },
      {
        "command": "simpleChat.selectFiles",
        "title": "Select Files for Context",
        "category": "Simple Chat"
      },
      {
        "command": "simpleChat.clearFiles",
        "title": "Clear File Context",
        "category": "Simple Chat"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Simple Chat",
      "properties": {
        "simple-chat.backendUrl": {
          "type": "string",
          "default": "https://code.johnheibel.com",
          "description": "URL of the trial backend API"
        },
        "simple-chat.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenRouter API key"
        },
        "simple-chat.model": {
          "type": "string",
          "default": "anthropic/claude-sonnet-4.5",
          "description": "Model to use for chat completions"
        },
        "simple-chat.baseUrl": {
          "type": "string",
          "default": "https://openrouter.ai/api/v1",
          "description": "API base URL"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "simpleChat.openChat",
          "when": "view == simpleChatView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node out/patchApplier.test.js",
    "test:integration": "npm run compile && node out/integration.test.js",
    "test:large": "npm run compile && node out/largeIntegration.test.js",
    "test:all": "npm run compile && node out/patchApplier.test.js && node out/integration.test.js && node out/largeIntegration.test.js"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.7.2"
  }
}
